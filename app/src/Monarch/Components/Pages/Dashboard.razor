@*
Conner Hammonds & Brady Brown
Monarch Dashboard Page
 - Displays a list of applications with their statuses,
 - Allows sorting by status or alphabetically
 - Allows filtering by all custom filters
 - Styles the page based on the Figma Mockup
*@

@page "/"
@using Monarch.Models
@using Monarch.Services
@using Microsoft.Data.SqlClient
@rendermode InteractiveServer
@inject AppCreationService CreationService
@inject AppLoadService LoadService

<PageTitle>Monarch</PageTitle>

<NavBar OnApplicationAdded="OnApplicationAdded" />

<div class="dashboard">
    <header class="dashboard-header">
        @if (isFilterDropdownOpen || isSortDropdownOpen)
        {
            <div class="dropdown-backdrop" @onclick="CloseDropdowns"></div>
        }   

        <div class="search-container">
            <input class="search-bar" type="text" @oninput="OnSearchInput" value="@searchQuery" placeholder="Search for apps by name"/>
        </div>

        <div class="filter-section">

            <div class="select-container">
                <button type="button" class="dropdown-toggle" @onclick="ToggleFilterDropdown">
                    Filter by: @(selectedFilterIds.Count == 0 ? "None" : $"{selectedFilterIds.Count} selected")
                </button>

                @if (isFilterDropdownOpen)
                {
                    <div class="dropdown-menu shadow">
                        @foreach (var filter in availableFilters)
                        {
                            <label class="dropdown-item checkbox">
                                <input type="checkbox"
                                       checked="@selectedFilterIds.Contains(filter.FilterId)"
                                       @onchange="@(e => OnFilterToggled(filter.FilterId, (bool)(e.Value ?? false)))" />
                                @filter.FilterName
                            </label>
                        }
                    </div>
                }
            </div>

            <div class="select-container">
        <button type="button" class="dropdown-toggle" @onclick="ToggleSortDropdown">
            Sort by: @(selectedSort == "status" ? "Status" : "Alphabetical")
        </button>

        @if (isSortDropdownOpen)
        {
            <div class="dropdown-menu shadow">
                <div class="dropdown-item @(selectedSort == "status" ? "selected" : "")" 
                     @onclick="@(() => SelectSort("status"))">
                    Status
                </div>
                <div class="dropdown-item @(selectedSort == "alpha" ? "selected" : "")" 
                     @onclick="@(() => SelectSort("alpha"))">
                    Alphabetical
                </div>
            </div>
        }
    </div>
        </div>
    </header>

    @if (isLoading)
    {
        <div class="loading">Loading applications...</div>
    }
    else if (!applications.Any())
    {
        <div class="no-data">No applications found. Waiting for data...</div>
    }
    else
    {
        <div class="applications-grid">
            @foreach (var app in applications)
            {
                <div class="@($"app-item {(draggingId == app.AppId ? "dragging" : string.Empty)} {(dragOverId == app.AppId ? "drag-over" : string.Empty)}")"
                    draggable="true" @ondragstart="@(() => OnDragStart(app.AppId))" @ondragover:preventDefault="true"
                    @ondragover="@(() => OnDragOver(app.AppId))" @ondrop="@(() => OnDrop(app.AppId))" @ondragend="OnDragEnd"
                    @key="app.AppId">
                    <ApplicationTile App="app" LastRefresh="lastRefresh"/>
                </div>
            }
        </div>
    }
    <div class="status-footer">        
        <div class="circular-timer" title="Refreshing in @(secondsRemaining)s">
            <svg width="24" height="24" viewBox="0 0 24 24">
                <circle class="timer-bg" cx="12" cy="12" r="10" />
                
                <circle class="timer-progress" cx="12" cy="12" r="10"
                        style="stroke-dashoffset: @(StrokeOffset)px;" />
            </svg>
        </div>
    </div>
</div>

@code {
    //List of applications currently displayed
    private List<AppModel> applications = new();
    //Backend list of applications for manipulation and then copied to currently displayed
    private List<AppModel> allApplications = new();
    //Default sort to status
    private string selectedSort = "status";
    //Set the search bar to empty
    private string? searchQuery = null;
    private int? draggingId;
    private int? dragOverId;
    private bool isLoading = true;
    private bool isFilterDropdownOpen = false;
    private bool isSortDropdownOpen = false;
    //Initialize a timer to show for page refreshing purposes
    private System.Threading.Timer? refreshTimer;
    //List of all filters currently in database
    private List<FilterModel> availableFilters = new();
    //List of ids of filters the user has selected
    private List<int> selectedFilterIds = new();
    //set initial seconds remaining to 30
    private int secondsRemaining = 30;
    //Circumference of circle for easy math with timer visualization
    private double circumference = 62.8;
    //Math done to show the countdown timer circle
    private double StrokeOffset => circumference - (circumference * ((double)secondsRemaining / 30));
    private int connFailNumber = 0;
    //DateTime to keep track of the latest time the page was refreshed
    //Initialized to the time the page loads
    private DateTime lastRefresh = DateTime.Now;

    private async Task OnApplicationAdded()
    {
        await LoadApplicationsFromDatabase();
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            availableFilters = await LoadService.GetAllFiltersAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading filters: {ex.Message}");
        }

        await LoadApplicationsFromDatabase();

        // Refresh data every 30 seconds to see live updates
        refreshTimer = new System.Threading.Timer(async _ =>
        {
            secondsRemaining--;
            if (secondsRemaining <= 0)
            {
                secondsRemaining = 30;
                await RefreshApplications();
            }

            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    private async Task LoadApplicationsFromDatabase()
    {
        try
        {
            var apps = await LoadService.GetMonarchAppsAsync();

            allApplications = apps;
            ApplySort();
            isLoading = false;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading applications: {ex.Message}");
            allApplications = new List<AppModel>();
            applications = new List<AppModel>();
            isLoading = false;
        }
    }

    private async Task RefreshApplications()
    {
        if (allApplications == null || !allApplications.Any()) return;

        try
        {
            var tasks = allApplications.Select<AppModel, Task<AppModel>>(async app => 
            {
                try 
                {
                    var status = await LoadService.RefreshAppStatusAsync(app.AppId);
                    var updatedApp = app;
                    updatedApp.Status = status;
                    return updatedApp;
                }
                catch 
                {
                    return app; 
                }
            });

            var refreshedApps = await Task.WhenAll(tasks);

            allApplications = refreshedApps.ToList();

            lastRefresh = DateTime.Now;
            
            ApplySort();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error during background refresh: {ex.Message}");
        }
    }

    private void SelectSort(string sortValue)
    {
        selectedSort = sortValue;
        isSortDropdownOpen = false;
        ApplySort();
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        searchQuery = e.Value?.ToString() ?? null;
        ApplySort();
    }

    private void ToggleFilterDropdown()
    {
        isFilterDropdownOpen = !isFilterDropdownOpen;
    }

    private void ToggleSortDropdown()
    {
        isSortDropdownOpen = !isSortDropdownOpen;
    }

    private void CloseDropdowns()
    {
        isFilterDropdownOpen = false;
        isSortDropdownOpen = false;
    }

    private void OnFilterToggled(int filterId, bool isChecked)
    {
        if (isChecked)
        {
            selectedFilterIds.Add(filterId);
        }
        else
        {
            selectedFilterIds.Remove(filterId);
        }

        ApplySort();
    }

    private void ApplySort()
    {

        var filteredApps = allApplications.AsEnumerable();

        if(searchQuery != null)
        {
            filteredApps = filteredApps.Where(app =>
                app.AppName.ToUpper().Contains(searchQuery.ToUpper()));
        }

        if (selectedFilterIds.Any())
        {
            filteredApps = filteredApps.Where(app =>
                selectedFilterIds.All(selectedId =>
                    app.Filters.Any(f => f.FilterId == selectedId)));
        }

        applications = selectedSort switch
        {
            "alpha" => filteredApps.OrderBy(a => a.AppName).ToList(),
            "status" => filteredApps
            .OrderBy(a => a.Status switch
            {
                StatusType.Outage => 0,
                StatusType.DegradedPerformance => 1,
                StatusType.Operational => 2,
                _ => 3
            })
            .ThenBy(a => a.AppName)
            .ToList(),
            _ => allApplications.ToList()
        };
    }

    // Drag & drop
    private void OnDragStart(int id)
    {
        draggingId = id;
    }

    private void OnDragOver(int overId)
    {
        dragOverId = overId;
        StateHasChanged();
    }

    private void OnDrop(int dropTargetId)
    {
        if (draggingId is null || draggingId == dropTargetId)
        {
            ClearDragState();
            return;
        }

        var fromIndex = applications.FindIndex(a => a.AppId == draggingId);
        var toIndex = applications.FindIndex(a => a.AppId == dropTargetId);
        if (fromIndex < 0 || toIndex < 0)
        {
            ClearDragState();
            return;
        }

        var item = applications[fromIndex];
        applications.RemoveAt(fromIndex);
        // After removal, the target index may shift if it was after the removed item
        if (fromIndex < toIndex) toIndex--;
        applications.Insert(toIndex, item);

        // Persist this as the new custom order baseline
        allApplications = applications.ToList();

        ClearDragState();
    }

    private void OnDragEnd()
    {
        ClearDragState();
    }

    private void ClearDragState()
    {
        draggingId = null;
        dragOverId = null;
        StateHasChanged();
    }

    public void Dispose()
    {
        refreshTimer?.Dispose();
    }
}

<style>
    .dashboard {
        padding: 24px;
        background-color: #2D2D2D;
        min-height: calc(100vh - 64px);
    }

    .dashboard-header {
        margin-bottom: 24px;
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 16px;
        width: 100%;
        position: relative;
        z-index: 10;
    }

    .filter-section {
        grid-column: 3;
        color: #A0A0A0;
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 12px;
    }

    .applications-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 16px;
    }

    .app-item {
        cursor: move;
        transition: all 0.3s cubic-bezier(0.4, 0.0, 0.2, 1);
        position: relative;
    }

    .app-item.dragging {
        opacity: 0.5;
        transform: scale(1.05);
        z-index: 20;
        transition: transform 0.2s ease, opacity 0.2s ease;
    }

    .app-item.drag-over {
        outline: 2px dashed rgba(255, 255, 255, 0.35);
        outline-offset: 2px;
        transform: scale(0.95);
        transition: all 0.2s ease;
    }

    .app-item:not(.dragging):not(.drag-over) {
        transform: scale(1);
    }

    .loading,
    .no-data {
        color: #A0A0A0;
        text-align: center;
        padding: 48px;
        font-size: 18px;
        font-family: 'Oswald', sans-serif;
    }
    
    .dropdown-toggle {
        background-color: #3D3D3D;
        color: #FFFFFF;
        border: 1px solid #5A5A5A;
        display: inline-flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
        cursor: pointer;
        padding: 6px 12px;
        border-radius: 6px;
        font-family: 'Oswald', sans-serif;
        font-size: 14px;
        height: 36px;
        box-sizing: border-box;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        transition: background-color 0.2s ease;
        z-index: 40;
    }

    .dropdown-toggle:hover{
        background-color: #4a4a4a;
    }

    .dropdown-menu{
        position: absolute;
        top: calc(100% + 4px);
        left: 0;
        width: 100%; 
        background-color: #3D3D3D;
        border: 1px solid #5A5A5A;
        border-radius: 6px;
        z-index: 50;
        max-height: 300px;
        overflow-y: auto;
        padding: 4px 0; 
        box-sizing: border-box;
        display: block;
    }

    .dropdown-item{
        display: block;
        padding: 8px 12px;
        color: #FFFFFF;
        cursor: pointer;
        font-family: 'Oswald', sans-serif;
        font-size: 14px;
        margin: 0;
        transition: background-color 0.2s ease;
    }

    .dropdown-item:hover,.dropdown-item.selected{
        background-color: #0078D4;
    }

    .checkbox{
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .checkbox input[type="checkbox"] {
        accent-color: #0078D4;
        cursor: pointer;
        margin: 0;
    }

    .dropdown-backdrop {
        position: fixed;
        top: 0; left: 0; width: 100vw; height: 100vh;
        z-index: 30;
    }

    .select-container{
        position: relative;
        display: inline-block;
        flex: 1;
        min-width: 140px;
        max-width: 180px;
    }

    .checkbox {
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: default;
    }

    .checkbox input[type="checkbox"] {
        accent-color: #0078D4; 
        margin: 0;
    }

    .search-container{
        grid-column: 2;
        display: flex;
        justify-content: center;
        width: 100%;
    }

    .search-bar{
        background-color: #3D3D3D;
        border: 1px solid #5A5A5A;
        border-radius: 6px;
        width: 100%;
        min-width: 400px;
        height: 34px;
        color: #FFFFFF;
        padding: 6px 12px;
        font-family: 'Oswald', sans-serif;
        font-size: 14px;
        box-sizing: border-box;
    }

    .search-bar::placeholder {
        color: #A0A0A0; 
    
    .status-footer {
        position: fixed;
        bottom: 0;
        left: 0;
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 8px 16px;
        background-color: transparent; 
        border-top-right-radius: 6px;
    }

    .status-text {
        color: #888;
        font-size: 14px;
    }

    .circular-timer svg {
        transform: rotate(-90deg);
        display: block;
    }

    .timer-bg {
        fill: none;
        stroke: #444; 
        stroke-width: 2.5;
    }

    .timer-progress {
        fill: none;
        stroke: #FFFFFF;
        stroke-width: 2.5;
        stroke-linecap: round;
        stroke-dasharray: 62.8; 
        transition: stroke-dashoffset 1s linear; 
    }

    @@media (max-width: 900px) {
        .dashboard-header {
            grid-template-columns: 1fr; 
            gap: 16px;
        }

        .search-container {
            grid-column: 1;
            order: 1;
        }

        .search-bar {
            max-width: 100%;
        }

        .filter-section {
            grid-column: 1;
            order: 2; 
            justify-content: space-between; 
        }

        .select-container {
            max-width: none;
        }
    }
</style>