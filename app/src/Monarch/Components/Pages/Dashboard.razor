@*
Conner Hammonds
Monarch Dashboard Page
 - Displays a list of applications with their statuses,
 - Allows sorting by status or alphabetically
 - Allows filtering by all custom filters
 - Styles the page based on the Figma Mockup
*@

@page "/"
@using Monarch.Models
@using Monarch.Services
@using Microsoft.Data.SqlClient
@rendermode InteractiveServer
@inject AppCreationService CreationService
@inject AppLoadService LoadService

<PageTitle>Monarch</PageTitle>

<NavBar />

<div class="dashboard">
    <header class="dashboard-header">
        <div class="filter-section">

            <!-- Below is a custom multi-select for filtering -->
            <div class="custom-multi-select">
                <!-- When clicked, dropdown will open -->
                <button class="filter-select dropdown-toggle" @onclick="ToggleFilterDropdown">
                    <!-- Shows amount of filters currently in use on dropdown cover -->
                    Filter by: @(selectedFilterIds.Count == 0 ? "None" : $"{selectedFilterIds.Count} selected")
                    <span class="dropdown-arrow">▼</span>
                </button>

                <!-- Code for when dropdown is open -->
                @if (isFilterDropdownOpen)
                {
                    <div class="dropdown-menu shadow">
                        <!-- Creates checkbox area for each filter in system -->
                        @foreach (var filter in availableFilters)
                        {
                            <label class="dropdown-item custom-checkbox">
                                <!-- Is already checked if the id of the filter is found in the list of selected filters -->
                                <!-- Calls filter toggle method when checkbox changes -->
                                <input  type="checkbox"
                                        checked="@selectedFilterIds.Contains(filter.FilterId)"
                                        @onchange="@(e => OnFilterToggled(filter.FilterId, (bool)(e.Value ?? false)))" />
                                @filter.FilterName
                            </label>
                        }
                    </div>
                }
            </div>

            <select class="sort-select" @onchange="OnSortChanged" value="@selectedSort">
                <option value="status">Sort by: Status</option>
                <option value="alpha">Sort by: Alphabetical</option>
            </select>
        </div>
    </header>

    @if (isLoading)
    {
        <div class="loading">Loading applications...</div>
    }
    else if (!applications.Any())
    {
        <div class="no-data">No applications found. Waiting for data...</div>
    }
    else
    {
        <div class="applications-grid">
            @foreach (var app in applications)
            {
                <div class="@($"app-item {(draggingId == app.AppId ? "dragging" : string.Empty)} {(dragOverId == app.AppId ? "drag-over" : string.Empty)}")"
                    draggable="true" @ondragstart="@(() => OnDragStart(app.AppId))" @ondragover:preventDefault="true"
                    @ondragover="@(() => OnDragOver(app.AppId))" @ondrop="@(() => OnDrop(app.AppId))" @ondragend="OnDragEnd"
                    @key="app.AppId">
                    <ApplicationTile App="app" />
                </div>
            }
        </div>
    }
</div>

@code {
    //List of applications currently displayed
    private List<AppModel> applications = new();
    //Backend list of applications for manipulation and then copied to currently displayed
    private List<AppModel> allApplications = new();
    private string selectedSort = "status";
    private int? draggingId;
    private int? dragOverId;
    private bool isLoading = true;
    private bool isFilterDropdownOpen = false;
    private System.Threading.Timer? refreshTimer;
    private List<FilterModel> availableFilters = new();
    private List<int> selectedFilterIds = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            availableFilters = await LoadService.GetAllFiltersAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading filters: {ex.Message}");
        }

        await LoadApplicationsFromDatabase();

        // Refresh data every 30 seconds to see live updates
        refreshTimer = new System.Threading.Timer(async _ =>
        {
            await RefreshApplications();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    private async Task LoadApplicationsFromDatabase()
    {
        try
        {
            var apps = await LoadService.GetMonarchAppsAsync();

            allApplications = apps;
            ApplySort();
            isLoading = false;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading applications: {ex.Message}");
            allApplications = new List<AppModel>();
            applications = new List<AppModel>();
            isLoading = false;
        }
    }

    private async Task RefreshApplications()
    {
        if (allApplications == null || !allApplications.Any()) return;

        try
        {
            var tasks = allApplications.Select<AppModel, Task<AppModel>>(async app => 
            {
                try 
                {
                    var status = await LoadService.RefreshAppStatusAsync(app.AppId);
                    var updatedApp = app;
                    updatedApp.Status = status;
                    return updatedApp;
                }
                catch 
                {
                    return app; 
                }
            });

            var refreshedApps = await Task.WhenAll(tasks);

            allApplications = refreshedApps.ToList();
            
            ApplySort();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error during background refresh: {ex.Message}");
        }
    }

    private void OnSortChanged(ChangeEventArgs e)
    {
        selectedSort = e.Value?.ToString() ?? "status";
        ApplySort();
    }

    private void ToggleFilterDropdown()
    {
        isFilterDropdownOpen = !isFilterDropdownOpen;
    }

    private void OnFilterToggled(int filterId, bool isChecked)
    {
        if (isChecked)
        {
            selectedFilterIds.Add(filterId);
        }
        else
        {
            selectedFilterIds.Remove(filterId);
        }

        ApplySort();
    }

    private void ApplySort()
    {

        var filteredApps = allApplications.AsEnumerable();

        if (selectedFilterIds.Any())
        {
            filteredApps = filteredApps.Where(app =>
                selectedFilterIds.All(selectedId =>
                    app.Filters.Any(f => f.FilterId == selectedId)));
        }

        applications = selectedSort switch
        {
            "alpha" => allApplications.OrderBy(a => a.AppName).ToList(),
            "status" => allApplications
            .OrderBy(a => a.Status switch
            {
                StatusType.Outage => 0,
                StatusType.DegradedPerformance => 1,
                StatusType.Operational => 2,
                _ => 3
            })
            .ThenBy(a => a.AppName)
            .ToList(),
            _ => allApplications.ToList()
        };
    }

    // Drag & drop
    private void OnDragStart(int id)
    {
        draggingId = id;
    }

    private void OnDragOver(int overId)
    {
        dragOverId = overId;
        StateHasChanged();
    }

    private void OnDrop(int dropTargetId)
    {
        if (draggingId is null || draggingId == dropTargetId)
        {
            ClearDragState();
            return;
        }

        var fromIndex = applications.FindIndex(a => a.AppId == draggingId);
        var toIndex = applications.FindIndex(a => a.AppId == dropTargetId);
        if (fromIndex < 0 || toIndex < 0)
        {
            ClearDragState();
            return;
        }

        var item = applications[fromIndex];
        applications.RemoveAt(fromIndex);
        // After removal, the target index may shift if it was after the removed item
        if (fromIndex < toIndex) toIndex--;
        applications.Insert(toIndex, item);

        // Persist this as the new custom order baseline
        allApplications = applications.ToList();

        ClearDragState();
    }

    private void OnDragEnd()
    {
        ClearDragState();
    }

    private void ClearDragState()
    {
        draggingId = null;
        dragOverId = null;
        StateHasChanged();
    }

    public void Dispose()
    {
        refreshTimer?.Dispose();
    }
}

<style>
    .dashboard {
        padding: 24px;
        background-color: #2D2D2D;
        min-height: calc(100vh - 64px);
    }

    .dashboard-header {
        margin-bottom: 24px;
        display: flex;
        justify-content: flex-end;
    }

    .filter-section {
        color: #A0A0A0;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .applications-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 16px;
    }

    .app-item {
        cursor: move;
        transition: all 0.3s cubic-bezier(0.4, 0.0, 0.2, 1);
        position: relative;
    }

    .app-item.dragging {
        opacity: 0.5;
        transform: scale(1.05);
        z-index: 1000;
        transition: transform 0.2s ease, opacity 0.2s ease;
    }

    .app-item.drag-over {
        outline: 2px dashed rgba(255, 255, 255, 0.35);
        outline-offset: 2px;
        transform: scale(0.95);
        transition: all 0.2s ease;
    }

    .app-item:not(.dragging):not(.drag-over) {
        transform: scale(1);
    }

    .sort-select {
        background-color: #3D3D3D;
        color: #FFFFFF;
        border: 1px solid #5A5A5A;
        padding: 6px 10px;
        border-radius: 6px;
        font-family: 'Oswald', sans-serif;
        font-size: 14px;
    }

    .loading,
    .no-data {
        color: #A0A0A0;
        text-align: center;
        padding: 48px;
        font-size: 18px;
        font-family: 'Oswald', sans-serif;
    }

    .filter-pills {
        display: flex;
        gap: 12px;
        align-items: center;
        margin-right: auto; /* Pushes the sort dropdown to the right */
    }

    .filter-label {
        color: #FFFFFF;
        font-family: 'Oswald', sans-serif;
    }
    
/* Wraps the button and the menu to keep them together */
    .custom-multi-select {
        position: relative;
        display: inline-block;
        margin-right: auto; /* Pushes the sort dropdown to the right */
    }

    /* Styles the button to perfectly match your existing sort select */
    .dropdown-toggle {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 160px;
        cursor: pointer;
    }

    .dropdown-arrow {
        font-size: 10px;
        margin-left: 8px;
    }

    /* The floating menu containing the checkboxes */
    .dropdown-menu {
        position: absolute;
        top: 110%;
        left: 0;
        width: 200px;
        background-color: #3D3D3D;
        border: 1px solid #5A5A5A;
        border-radius: 6px;
        z-index: 2000;
        max-height: 300px;
        overflow-y: auto;
        padding: 8px 0;
    }

    /* Styles each individual row in the menu */
    .dropdown-item {
        display: block;
        padding: 8px 16px;
        color: #FFFFFF;
        cursor: pointer;
        font-family: 'Oswald', sans-serif;
        font-size: 14px;
        transition: background-color 0.2s;
    }

    .dropdown-item:hover {
        background-color: #4D4D4D;
    }

    /* Keeps your checkbox styling */
    .custom-checkbox {
        display: flex;
        align-items: center;
        gap: 8px;
        margin: 0;
    }
    .custom-checkbox input[type="checkbox"] {
        accent-color: #d9534f;
        cursor: pointer;
    }
</style>