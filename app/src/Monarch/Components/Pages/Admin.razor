@*
Conner Hammonds & Brady Brown
Monarch Admin Page
 - Google form style app configuration
 - Select or create an application
 - Connect New Relic and Nagios monitoring APIs
 - Assign Jira workspaces and Slack channels
 - Confirm and save changes to the database
*@

@page "/admin"
@using Microsoft.AspNetCore.Authentication.OAuth.Claims
@using Microsoft.Identity.Client
@using Monarch.Components
@using Monarch.Models
@using Monarch.Services
@using Microsoft.AspNetCore.Authorization
@using System.Runtime.CompilerServices
@attribute [Authorize(Policy = "Admin")]
@inject AppAdminService AdminService
@inject SlackAdminService SlackService
@inject AppLoadService LoadService

@rendermode InteractiveServer

<PageTitle>Admin Console - Monarch</PageTitle>

<NavBar />

<div class="admin-page">
    <h1>Admin Console</h1>
    <p class="admin-subtitle">Configure application monitoring integrations and notification routing.</p>

    <!-- STEP 1: Select or Create Application -->
    <div class="form-section">
        <div class="section-number">1</div>
        <div class="section-content">
            <h2>Select Application</h2>
            <p class="section-description">Choose an existing application to configure, or create a new one.</p>

            <div class="form-group">
                <label>Application</label>
                <div class="app-select-row">
                    <select @bind="selectedAppId" @bind:after="OnAppSelected">
                        <option value="0">-- Select an application --</option>
                        @foreach (var app in monarchApps)
                        {
                            <option value="@app.AppId">@app.AppName</option>
                        }
                    </select>

                </div>
            </div>
        </div>
    </div>

    @if (currentApp != null)
    {
        <!-- STEP 2: Monitoring Connections (auto-discovered) -->
        <div class="form-section">
            <div class="section-number">2</div>
            <div class="section-content">
                <h2>Monitoring Connections</h2>
                <p class="section-description">Monitoring sources are automatically discovered by the monapi-worker service. These connections are read-only.</p>

                <div class="connection-display">
                    <div class="connection-row">
                        <span class="connection-label">New Relic</span>
                        @if (currentApp.NewRelicId != null)
                        {
                            var nrApp = discoveredNewRelicApps.FirstOrDefault(a => a.AppId == currentApp.NewRelicId);
                            <span class="connection-value connected">
                                @(nrApp != null ? $"{nrApp.AppName} ({nrApp.AppId})" : currentApp.NewRelicId)
                                <span class="auto-badge">Auto-discovered</span>
                            </span>
                        }
                        else
                        {
                            <span class="connection-value not-connected">Not linked</span>
                        }
                    </div>
                    <div class="connection-row">
                        <span class="connection-label">Nagios</span>
                        @if (currentApp.NagiosId != null)
                        {
                            var nagApp = discoveredNagiosApps.FirstOrDefault(a => a.AppId == currentApp.NagiosId);
                            <span class="connection-value connected">
                                @(nagApp != null ? $"{nagApp.AppName} ({nagApp.AppId})" : currentApp.NagiosId)
                                <span class="auto-badge">Auto-discovered</span>
                            </span>
                        }
                        else
                        {
                            <span class="connection-value not-connected">Not linked</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- STEP 3: Filtering -->
        <div class="form-section">
            <div class="section-number">3</div>
            <div class="section-content">
                <h2>Custom Filters</h2>
                <p class="section-description">Assign custom tags to help categorize this app on the dashboard. Search for an existing filter, or type a new name and press Enter to create it.</p>

                <div class="searchable-multi-select">
                    <div class="search-box">
                        <input type="text" 
                               placeholder="Search filters or type to create new..." 
                               @bind="filterSearchText" 
                               @bind:event="oninput" 
                               @onkeydown="HandleFilterKeyDown" />
                        @if (!string.IsNullOrWhiteSpace(filterSearchText) && !FilteredFilters.Any(f => f.FilterName.Equals(filterSearchText, StringComparison.OrdinalIgnoreCase)))
                        {
                            <span class="create-hint">Press Enter to create</span>
                        }
                    </div>

                    <div class="checkbox-list">
                        @if (FilteredFilters.Any())
                        {
                            @foreach (var filter in FilteredFilters)
                            {
                                var isChecked = activeAppFilterIds.Contains(filter.FilterId);
                                <div class="filter-row">
                                    <label class="filter-label">
                                        <input type="checkbox" checked="@isChecked" 
                                            @onchange="(e) => ToggleFilter(filter.FilterId, (bool)(e.Value ?? false))" />
                                        <span class="checkbox-label-text">
                                            @filter.FilterName
                                        </span>
                                    </label>
                                    
                                    <div class="filter-actions">
                                        <button class="btn-mini" @onclick="() => PromptDelete(DeleteTarget.Filter, filter.FilterId, filter.FilterName)">Delete</button>
                                    </div>
                                </div>
                            }
                        }
                        else if (string.IsNullOrWhiteSpace(filterSearchText))
                        {
                            <div class="empty-state">No filters created yet.</div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- STEP 4: Jira Workspaces -->
        <div class="form-section">
            <div class="section-number">4</div>
            <div class="section-content">
                <h2>Jira Workspaces</h2>
                <p class="section-description">Select which Jira workspaces should receive incident tickets for this application. You can select one or many.</p>

                @if (jiraWorkspaces.Any())
                {
                    <div class="checkbox-list">
                        @foreach (var workspace in jiraWorkspaces)
                        {
                            var isChecked = currentApp.SelectedJiraWorkspaces.Contains(workspace.WorkspaceKey);
                            <div class="checkbox-item-with-button">
                                <label class="checkbox-item">
                                    <input type="checkbox" checked="@isChecked"
                                        @onchange="(e) => ToggleJiraWorkspace(workspace.WorkspaceKey, (bool)(e.Value ?? false))" />
                                    <span class="checkbox-label-text">
                                        <strong>@workspace.WorkspaceKey</strong>
                                        <span class="checkbox-detail">@workspace.BaseUrl</span>
                                    </span>
                                </label>
                                <button class="btn-test" @onclick="() => SendTestTicket(workspace.WorkspaceKey)" 
                                        disabled="@testTicketSending">Send Test Ticket</button>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="info-message">No Jira workspaces have been configured yet. Add a workspace below.</p>
                }

                @if (!string.IsNullOrEmpty(testTicketStatus))
                {
                    <p class="@testTicketStatusClass">@testTicketStatus</p>
                }

                <div class="add-workspace-row">
                    <input type="text" @bind="newJiraWorkspace.WorkspaceKey" placeholder="Project Key (e.g., MON)" />
                    <input type="text" @bind="newJiraWorkspace.BaseUrl" placeholder="Base URL (e.g., https://team.atlassian.net)" />
                    <button class="btn-secondary" @onclick="AddJiraWorkspace">Add</button>
                </div>
            </div>
        </div>

        <!-- STEP 5: Slack Channels -->
        <div class="form-section">
            <div class="section-number">5</div>
            <div class="section-content">
                <h2>Slack Channels</h2>
                <p class="section-description">Select which Slack channels should receive notifications for this application. You can select one or many.</p>

                @if (slackChannels.Any())
                {
                    <div class="checkbox-list">
                        @foreach (var channel in slackChannels)
                        {
                            var isChecked = currentApp.SelectedSlackChannels.Contains(channel.Key);
                            <label class="checkbox-item">
                                <input type="checkbox" checked="@isChecked"
                                    @onchange="(e) => ToggleSlackChannel(channel.Key, (bool)(e.Value ?? false))" />
                                <span class="checkbox-label-text">
                                    <strong>@channel.ChannelName</strong>
                                    <span class="checkbox-detail">@channel.Key @(channel.IsDefault ? "(default)" : "")</span>
                                </span>
                            </label>
                        }
                    </div>
                }
                else
                {
                    <p class="info-message">No Slack channels have been configured. Add channels in the Slack channel management section or the Slack admin config.</p>
                }
            </div>
        </div>

        <!-- STEP 6: Confirm & Save -->
        <div class="form-section">
            <div class="section-number">6</div>
            <div class="section-content">
                <h2>Review & Save</h2>
                <p class="section-description">Review the configuration below and click save to apply changes.</p>

                <div class="review-summary">
                    <div class="review-row">
                        <span class="review-label">Application</span>
                        <span class="review-value">@currentApp.AppName</span>
                    </div>
                    <div class="review-row">
                        <span class="review-label">New Relic</span>
                        <span class="review-value">
                            @if (currentApp.NewRelicId != null)
                            {
                                var nrApp = discoveredNewRelicApps.FirstOrDefault(a => a.AppId == currentApp.NewRelicId);
                                @(nrApp != null ? $"{nrApp.AppName} ({nrApp.AppId})" : currentApp.NewRelicId)
                            }
                            else
                            {
                                <span class="not-configured">Not connected</span>
                            }
                        </span>
                    </div>
                    <div class="review-row">
                        <span class="review-label">Nagios</span>
                        <span class="review-value">
                            @if (currentApp.NagiosId != null)
                            {
                                var nagApp = discoveredNagiosApps.FirstOrDefault(a => a.AppId == currentApp.NagiosId);
                                @(nagApp != null ? $"{nagApp.AppName} ({nagApp.AppId})" : currentApp.NagiosId)
                            }
                            else
                            {
                                <span class="not-configured">Not connected</span>
                            }
                        </span>
                    </div>
                    <div class="review-row">
                        <span class="review-label">Filters</span>
                        <span class="review-value">
                            @if (activeAppFilterIds.Any())
                            {
                                var selectedNames = availableFilters
                                    .Where(f => activeAppFilterIds.Contains(f.FilterId))
                                    .Select(f => f.FilterName);
                                @string.Join(", ", selectedNames)
                            }
                            else
                            {
                                <span class="not-configured">No filters selected</span>
                            }
                        </span>
                    </div>
                    <div class="review-row">
                        <span class="review-label">Jira</span>
                        <span class="review-value">
                            @if (currentApp.SelectedJiraWorkspaces.Any())
                            {
                                @string.Join(", ", currentApp.SelectedJiraWorkspaces)
                            }
                            else
                            {
                                <span class="not-configured">No workspaces selected</span>
                            }
                        </span>
                    </div>
                    <div class="review-row">
                        <span class="review-label">Slack</span>
                        <span class="review-value">
                            @if (currentApp.SelectedSlackChannels.Any())
                            {
                                @string.Join(", ", currentApp.SelectedSlackChannels)
                            }
                            else
                            {
                                <span class="not-configured">No channels selected</span>
                            }
                        </span>
                    </div>
                </div>

                <div class="save-actions">
                    <div class="action-group-left">
                        <button class="btn-primary btn-large" @onclick="SaveConfiguration">Save Changes</button>
                        <button class="btn-secondary" @onclick="ResetForm">Discard</button>
                    </div>

                    <button class="btn-delete btn-large" @onclick="() => PromptDelete(DeleteTarget.App, currentApp.AppId, currentApp.AppName)">Delete Configuration</button>
                </div>

                @if (!string.IsNullOrEmpty(saveStatus))
                {
                    <div class = "@saveStatusClass">
                        <p class="status-message">@saveStatus</p>
                        <p class="refresh-timer">@($"Page will refresh in {timeTilRefresh}")</p>
                    </div>
                }
            </div>
        </div>
    }
</div>
@if (showDeleteConfirmation)
{
    <div class="modal-backdrop">
        <div class="custom-modal shadow">
            <h3>Confirm Deletion</h3>
            @if(currentDeleteTarget == DeleteTarget.App)
            {
                <p>Are you sure you want to delete this configuration for <strong>@itemToDeleteName</strong>? This action cannot be undone.</p>

                <div class="modal-validation-group">
                    <label>Please type <strong>@itemToDeleteName</strong> to confirm:</label>
                    <input type="text" @bind="confirmNameInput" @bind:event="oninput" autocomplete="off" placeholder="Type name here..." />
                </div>
            } 
            else
            {
                <p>Are you sure you want to delete the filter <strong>@itemToDeleteName</strong>? This action cannot be undone.</p>
            }

            <div class="modal-actions">
                <button class="btn-secondary" @onclick="CancelDelete">Cancel</button>
                <button class="btn-delete" @onclick="ConfirmDelete" disabled="@IsDeleteDisabled">Delete</button>
            </div>
        </div>
    </div>
}

@code {
      /*
    Admin Razor Logic
    Code that detemines all logic for the Admin page
    Includes the following:
      - Variables
        - Data Collection Variables
          - List<AppModel> monarchApps
          - List<NewRelicApp> discoveredNewRelicApps
          - List<NagiosApp> discoveredNagiosApps
          - List<FilterModel> availableFilters
          - List<SlackChannel> slackChannels
          - List<JiraWorkspaceOption> jiraWorkspaces
        - Form State Variables
          - Parameter int passedAppId (nullable)
          - int selectedAppId
          - AppModel currentApp
          - string filterSearchText
          - List<int> activeAppFilterIds
          - JiraWorkspaceOption newJiraWorkspace
        - Deletion Variables
          - enum DeleteTarget
          - bool showDeleteConfirmation
          - DeleteTarget currentDeleteTarget
          - int itemToDeleteId
          - string itemToDeleteName
          - string confirmNameInput
        - Miscellaneous Variables
          - IEnumerable<FilterModel> FilteredFilters
          - string saveStatus
          - string saveStatusClass
          - string testTicketStatus
          - string testTicketStatusClass
          - bool testTicketSending
          - int timeTilRefresh
      - Methods
        - Initialization Methods
          - OnInitializedAsync()
          - OnParametersSetAsync()
          - LoadAllData()
          - OnAppSelected()
        - Deletion Methods
          - PromptDelete(DeleteTarget, int, string)
          - CancelDelete()
          - ConfirmDelete()
          - bool IsDeleteDisabled **is a variable**
        - Filter Methods
          - ToggleFilter(int, bool)
          - HandleFilterKeyDown(KeyboardEventArgs)
          - DeleteFilter(int)
        - Miscellaneous Methods
          - ToggleSlackChannel(string, bool)
          - ToggleJiraWorkspace(string, bool)
          - AddJiraWorkspace()
          - SaveConfiguration()
          - ResetForm()
          - RefreshAsync()
          - DeleteConfiguration(int)
          - SendTestTicket(string)


  */

    //Variables

    //Data Collection Variables

    //List of all Monarch apps in Monarch DB
    private List<AppModel> monarchApps = new();

    //List of all New Relic apps in Monapi DB
    private List<NewRelicApp> discoveredNewRelicApps = new();

    //List of all Nagios apps in Monapi DB
    private List<NagiosApp> discoveredNagiosApps = new();

    //List of all filters in Monarch DB
    private List<FilterModel> availableFilters = new();

    //List of all Slack channels currently configured
    private List<SlackChannel> slackChannels = new();

    //List of all Jira workspaces in Monarch DB
    private List<JiraWorkspaceOption> jiraWorkspaces = new();
    

    //Form State Variables

    //Parameter from Application Tile
    //App id that is passed if admin accessed via app "edit" icon
    [Parameter]
    [SupplyParameterFromQuery(Name = "appId")]
    public int? passedAppId { get; set; }

    //Currently selected app's id
    //Default to none
    private int selectedAppId = 0;

    //App model available for configuration
    private AppModel? currentApp;

    //Filter input text
    private string filterSearchText = "";

    //List of app's currently active filters
    private List<int> activeAppFilterIds = new();

    //Jira workspace blank configuration
    //New workspaces can be configured by the user if necessary
    private JiraWorkspaceOption newJiraWorkspace = new();


    //Deletion Variables

    //Custom variable for help with deletion
    //Used to change deletion popup based on item type being deleted
    private enum DeleteTarget
    {
        App,
        Filter
    }

    //Boolean for deletion confirmation popup
    private bool showDeleteConfirmation = false;

    //Current item deletion type
    private DeleteTarget currentDeleteTarget;

    //Current item deletion id
    private int itemToDeleteId;

    //Current item deletion name
    private string itemToDeleteName = "";

    //string for app confirm delete input
    private string confirmNameInput = "";


    //Miscellaneous Variables

    //List of filters based on filter input text
    //Filter input is used as creation and search
    //Helpful when there are lots of filters to scroll through
    private IEnumerable<FilterModel> FilteredFilters =>
        string.IsNullOrWhiteSpace(filterSearchText)
            ? availableFilters //Displays all filters if bar is empty
            : availableFilters.Where(f => 
                f.FilterName.Contains(filterSearchText, StringComparison.OrdinalIgnoreCase)); //Only displays filters that include current input if there is input

    //Text for save message
    private string saveStatus = "";

    //String for CSS class for save message
    private string saveStatusClass = "status-box";

    //Text for test ticket message
    private string testTicketStatus = "";

    //String for CSS class for test ticket message
    private string testTicketStatusClass = "status-box";

    //Boolean to show state of test ticket submission
    private bool testTicketSending = false;

    //Amount of time left until the page will refresh after deletion
    //Used for a countdown that appears in the status confirmation bar
    private int timeTilRefresh;
    

    //Methods

    //Initialization Methods

    protected override async Task OnInitializedAsync()
    {
        await LoadAllData();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (passedAppId.HasValue && selectedAppId != passedAppId.Value)
        {
            selectedAppId = passedAppId.Value;
            await OnAppSelected();
        }
    }

    /// <summary>
    /// Loads all dropdown/list data from the database and services
    /// </summary>
    private async Task LoadAllData()
    {
        try
        {
            monarchApps = await LoadService.GetMonarchAppsAsync();
            discoveredNewRelicApps = await AdminService.GetDiscoveredNewRelicAppsAsync();
            discoveredNagiosApps = await AdminService.GetDiscoveredNagiosAppsAsync();
            availableFilters = await LoadService.GetAllFiltersAsync();
            slackChannels = SlackService.GetChannels();
            jiraWorkspaces = await AdminService.GetJiraWorkspacesAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading admin data: {ex.Message}");
        }
    }

    /// <summary>
    /// Handles app selection from the dropdown
    /// </summary>
    private async Task OnAppSelected()
    {
        saveStatus = "";
        activeAppFilterIds.Clear();
        if (selectedAppId > 0)
        {
            currentApp = await LoadService.GetAppByIdAsync(selectedAppId);
        }
        else
        {
            currentApp = null;
        }
    }


    //Deletion Methods

    /*
    Brady Brown
    PromptDelete Method
    Method for when a delete button is selected
    Uses the same method regardless of app or filter deletion
    Ends with visualization of delete popup
    */
    private void PromptDelete(DeleteTarget target, int id, string name){

        //Sets the item type based on what delete button was selected
        currentDeleteTarget = target;

        //Identification of item selected
        itemToDeleteId = id;
        itemToDeleteName = name;

        //Sets confirmation prompt to empty
        //Only shows up if app is the item type
        confirmNameInput = "";

        //After all variables are properly set, popup appears
        showDeleteConfirmation = true;
    }

    /*
    Brady Brown
    CancelDelete Method
    Method for when delection action is cancelled
    */
    private void CancelDelete()
    {
        //Simply makes popup disappear
        showDeleteConfirmation = false;
    }

    /*
    Brady Brown
    ConfirmDelete Method
    Method for when delection action is confirmed
    Calls other deletion methods based upon deletion target
    */

    private async Task ConfirmDelete()
    {
        //Makes popup disappear, then actions happen
        //Deletion confirmation will appear outside of popup window
        showDeleteConfirmation = false;

        //If the target is an app, calls the app deletion method
        //Otherwise, the filter method is called, as there is no other option
        if (currentDeleteTarget == DeleteTarget.App)
        {
            await DeleteConfiguration(itemToDeleteId);
        } else {
            await DeleteFilter(itemToDeleteId);
        }
    }


    //Boolean for if the delete button is currently disabled
    //Is disabled until delete confirmation input matches the name of the configuration
    //Only used for deletion of apps
    private bool IsDeleteDisabled =>
        currentDeleteTarget == DeleteTarget.App && //Confirms that deletion is an app
        !string.Equals(confirmNameInput, itemToDeleteName, StringComparison.OrdinalIgnoreCase); //Checks to see if input box has the name(ignores case)

    
    //Filter Methods 

    /*
    Brady Brown
    ToggleFilter Method
    Method that handles when filters are toggled on and off
    */
    private void ToggleFilter(int filterId, bool isChecked)
    {
        //Checks to see if filter has now been checked and if the list of active filters does not contain the id of the filter
        if (isChecked && !activeAppFilterIds.Contains(filterId))
        {
            //if so, adds the filter to the list
            activeAppFilterIds.Add(filterId);
        }
        else if (!isChecked)//Checks to make sure the filter is not checked
        {
            //If so, removes it from the list of active filters
            activeAppFilterIds.Remove(filterId);
        }
    }

    /*
    Brady Brown
    HandleFilterKeyDown Method
    Method for handling keyboard events when in filter textbox
    Primarily used for adding new filters with the enter button
    If there is a match for the filter that has been typed, enter will add the filter to the list
    */
    private async Task HandleFilterKeyDown(KeyboardEventArgs e)
    {
        //Checks for if the key pressed is enter and if the text box has content
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(filterSearchText))
        {
            //If so, checks for the first filter in the list that has the filter name equal to the input box
            //Ignores casing, to ensure that filters with too similar of names are not added
            //For instance, there is no need for a "Hardware" filter and a "hardware" filter
            var exactMatch = availableFilters.FirstOrDefault(f => f.FilterName.Equals(filterSearchText, StringComparison.OrdinalIgnoreCase));

            //Checks to see if the match doesn't exist
            if (exactMatch == null)
            {
                try
                {
                    //If so, calls the CreateFilterAsync method from AdminService with the input
                    //Removes whitespace at the end for entry and returns the auto-id of the new filter
                    int newId = await AdminService.CreateFilterAsync(filterSearchText.Trim());
                    //Creates a new FilterModel that is set to the auto-id and input text
                    var newFilter = new FilterModel { FilterId = newId, FilterName = filterSearchText.Trim() };

                    //The newly added filter is added to available filters
                    availableFilters.Add(newFilter);
                    //The filter is then added to the list of active filters
                    activeAppFilterIds.Add(newId);
                    //Current text in the textbox is now removed as process is over
                    filterSearchText = "";
                }
                catch (Exception ex)
                {
                    //Catches exceptions when connecting to Monarch DB
                    //If error, shows error in save message box
                    saveStatus = $"Error creating filter: {ex.Message}";
                    saveStatusClass = "status-messsage status-error";
                }
            }
            else
            //Only done if match is found in list
            {
                //Checks to see if the list of active filters doesn't contain the filter
                if (!activeAppFilterIds.Contains(exactMatch.FilterId))
                {
                    //If so, is added to the list of filters
                    activeAppFilterIds.Add(exactMatch.FilterId);
                }
                //Text is removed from filter search as process is over
                filterSearchText = "";
            }
        }
    }

    /*
    Brady Brown
    DeleteFilter Method
    Method that handles deletion confirmation of filter type
    Takes input of the filter's id
    */

    private async Task DeleteFilter(int filterId)
    {
        try
        {
            //Calls the deletion method from AdminService
            await AdminService.DeleteFilterAsync(filterId);

            //Updates the state of the form to remove the filter from list
            StateHasChanged();

            //Loads all data to ensure that all content matches the updated database
            await LoadAllData();
        }
        catch (Exception ex)
        {
            //Catches exceptions when connecting to the Monarch DB
            //If error, shows error message in save message box
            saveStatus = $"Error deleting filter: {ex.Message}";
            saveStatusClass = "status-box status-error";
        }
    }

    //Miscellaneous Methods

    // ===== Multi-Select Toggles =====
    private void ToggleSlackChannel(string channelKey, bool isChecked)
    {
        if (currentApp == null) return;

        if (isChecked && !currentApp.SelectedSlackChannels.Contains(channelKey))
        {
            currentApp.SelectedSlackChannels.Add(channelKey);
        }
        else if (!isChecked)
        {
            currentApp.SelectedSlackChannels.Remove(channelKey);
        }

        currentApp.SlackAlert = currentApp.SelectedSlackChannels.Any();
    }

    private void ToggleJiraWorkspace(string workspaceKey, bool isChecked)
    {
        if (currentApp == null) return;

        if (isChecked && !currentApp.SelectedJiraWorkspaces.Contains(workspaceKey))
        {
            currentApp.SelectedJiraWorkspaces.Add(workspaceKey);
        }
        else if (!isChecked)
        {
            currentApp.SelectedJiraWorkspaces.Remove(workspaceKey);
        }

        currentApp.JiraAlert = currentApp.SelectedJiraWorkspaces.Any();
    }

    // ===== Add Jira Workspace =====

    private async Task AddJiraWorkspace()
    {
        if (string.IsNullOrWhiteSpace(newJiraWorkspace.WorkspaceKey) ||
            string.IsNullOrWhiteSpace(newJiraWorkspace.BaseUrl))
            return;

        try
        {
            // Use workspace key as the name
            newJiraWorkspace.WorkspaceName = newJiraWorkspace.WorkspaceKey;
            
            await AdminService.AddJiraWorkspaceAsync(newJiraWorkspace);
            newJiraWorkspace = new JiraWorkspaceOption();
            jiraWorkspaces = await AdminService.GetJiraWorkspacesAsync();
        }
        catch (Exception ex)
        {
            saveStatus = $"Error adding Jira workspace: {ex.Message}";
            saveStatusClass = "status-box status-error";
        }
    }

    // ===== Save & Reset =====

    private async Task SaveConfiguration()
    {
        if (currentApp == null) return;

        try
        {
            // Track which Slack channels are newly added
            var previousChannels = new List<string>();
            if (currentApp.AppId > 0)
            {
                var existingApp = await LoadService.GetAppByIdAsync(currentApp.AppId);
                if (existingApp != null)
                {
                    previousChannels = existingApp.SelectedSlackChannels;
                }
            }
            var newlyAddedChannels = currentApp.SelectedSlackChannels
                .Where(c => !previousChannels.Contains(c))
                .ToList();

            // Update with all mappings
            await AdminService.UpdateAppAsync(currentApp);

            await AdminService.SaveAppFiltersAsync(currentApp.AppId, activeAppFilterIds);

            // Send Slack notification to newly added channels
            foreach (var channelKey in newlyAddedChannels)
            {
                var channel = slackChannels.FirstOrDefault(c => c.Key == channelKey);
                if (channel != null)
                {
                    await SlackService.SendChannelNotificationAsync(
                        channel.Key,
                        $"{channel.ChannelName} has been added to the automated slack notifications from Monarch for {currentApp.AppName}."
                    );
                }
            }

            saveStatus = $"Configuration for '{currentApp.AppName}' saved successfully. Changes will be reflected on the dashboard.";
            saveStatusClass = "status-box status-success";

            // Reload to reflect saved state
            await LoadAllData();
            selectedAppId = currentApp.AppId;
        }
        catch (Exception ex)
        {
            saveStatus = $"Error saving configuration: {ex.Message}";
            saveStatusClass = "status-box status-error";
        }
    }

    private void ResetForm()
    {
        currentApp = null;
        selectedAppId = 0;
        saveStatus = "";
        testTicketStatus = "";
    }

    /*
    Brady Brown
    RefreshAsync Method
    Method that automatically refreshes the page and removes the currently selected app
    Only used when an app is deleted
    */
    private async Task RefreshAsync()
    {
        //For loop that is used to keep track of time
        //Only lasts 3 seconds
        for(int i = 3; i > 0; i--)
        {
            //Sets the time til refresh to the amount of time now left
            timeTilRefresh = i;
            //Updates state of page to show correct time left
            StateHasChanged();
            //Waits 1 second
            await Task.Delay(1000);
        }

        //After time is done, loads proper data from DB
        await LoadAllData();
        //Sets current app to null and id to 0
        currentApp = null;
        selectedAppId = 0;
    }

    /*
    Brady Brown
    DeleteConfiguration Method
    Method that handles deletion confirmation of application type
    Takes input of the app's id
    */
    private async Task DeleteConfiguration(int id)
    {
        //Checks to see if the current app does not exist
        //If so, do nothing as there is nothing selected to delete
        if(currentApp == null) return;

        try
        {
            //Set deleted app name to the current app name
            var deletedAppName = currentApp.AppName;
            //Calls the DeleteAppAsync method from AppAdminService
            await AdminService.DeleteAppAsync(id);
            //Shows a confirmation message that the app with specified name has been deleted
            saveStatus = $"Configuration for '{deletedAppName}' deleted successfully. Changes will be reflected on the dashboard.";
            saveStatusClass = "status-box status-success";

            //Updates current state of the page to ensure all variables are displayed properly
            StateHasChanged();

            //Calls an automatic page refresh
            //This is done because the page can no longer edit the selected app, as it no longer exists
            //Shows a timer in the confirmation message until refresh
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            //Catches exceptions when connecting to the Monarch DB
            //If error, shows error message in save message box
            saveStatus = $"Error deleting configuration: {ex.Message}";
            saveStatusClass = "status-box status-error";
        }
    }

    // ===== Send Test Jira Ticket =====

    private async Task SendTestTicket(string workspaceKey)
    {
        testTicketSending = true;
        testTicketStatus = "Sending test ticket...";
        testTicketStatusClass = "status-box status-info";

        try
        {
            var result = await AdminService.SendTestJiraTicketAsync(workspaceKey);
            
            if (result.success)
            {
                testTicketStatus = result.message;
                testTicketStatusClass = "status-box status-success";
            }
            else
            {
                testTicketStatus = result.message;
                testTicketStatusClass = "status-box status-error";
            }
        }
        catch (Exception ex)
        {
            testTicketStatus = $"Error sending test ticket: {ex.Message}";
            testTicketStatusClass = "status-box status-error";
        }
        finally
        {
            testTicketSending = false;
        }
    }
}

