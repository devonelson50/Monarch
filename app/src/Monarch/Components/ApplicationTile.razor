@*
Conner Hammonds
Monarch Application Tile Component
 - Displays individual application status tiles
 - Expandable to show more details
*@

@using Monarch.Models
@using Monarch.Services
@using Microsoft.AspNetCore.Components.Authorization

@inject AppLoadService LoadService

<div class="app-tile @GetStatusClass() @(IsExpanded ? "expanded" : string.Empty)">
    <div class="tile-header">
        <span class="app-name">@App.AppName</span>
        <div class="status-indicator">
            <span class="status-dot"></span>
            <button class="expand-btn" title="Expand" aria-label="Expand" aria-expanded="@IsExpanded"
                @onclick="ExpandAsync">
                <svg class="expand-icon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
                    <path fill="currentColor"
                        d="M7 3H3v4h2V5h2V3zm12 0h-4v2h2v2h2V3zM5 17H3v4h4v-2H5v-2zm14 0h-2v2h-2v2h4v-4z" />
                </svg>
            </button>
            <AuthorizeView Policy="Admin">
                <Authorized>
                    <a class="edit-btn" title="Edit" aria-label="Edit" href="/admin?appId=@App.AppId">
                        <svg class="edit-icon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
                            <path fill="currentColor"
                                d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" />                </svg>
                    </a>
                </Authorized>
            </AuthorizeView>
        </div>
    </div>

    @if (IsExpanded)
    {
        <div class="details">
            @if (isLoadingDetails)
            {
                <div class="loading-state">
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                    Loading live metrics...
                </div>
            }
            else if (details != null)
            {
                <div class="section-divider span-full">
                    <span>General Details</span>
                </div>

                <div class="metric-grid">

                    <div class="metric-row">
                        <span class="label">IP:</span>
                        <span class="value">@details.IpAddress</span>
                    </div>

                    <div class="metric-row">
                        <span class="label">Last Updated:</span>
                        <span class="value">@($"{LastRefresh:HH:mm:ss}")</span>
                    </div>

                </div>

                @if (App.NewRelicId != null)
                {                          
                    <div class="section-divider span-full">
                        <span>New Relic</span>
                    </div>

                    <div class="metric-grid">

                        <div class="metric-row">
                            <span class="label">CPU Usage:</span>
                            <span class="value">@details.nrCpuUsage.ToString("0.0")%</span>
                            <div class="bar-track">
                                <div class="bar-fill span-full @GetDynamicBarColor(details.nrCpuUsage)" style="width: @Math.Min(details.nrCpuUsage, 100)%"></div>
                            </div>
                        </div>

                        <div class="metric-row">
                            <span class="label">Latency:</span>
                            <span class="value">@details.nrLatency ms</span>
                            <div class="bar-track">
                                <div class="bar-fill @GetDynamicBarColor(details.nrLatency / 2)" style="width: @(Math.Min(details.nrLatency / 2, 100))%"></div>
                            </div>
                        </div>

                        <div class="metric-row span-full">
                            <span class="label">Status:</span>
                            <span class="bar-full @GetNagiosStateClass(details.nrStatus)">
                                @GetNagiosStateLabel(details.nrStatus)</span>
                        </div>

                    </div>
                }

                @if (App.NagiosId != null)
                {
                    <div class="section-divider span-full">
                        <span>Nagios</span>
                    </div>

                    <div class="metric-grid">

                        <div class="metric-row">
                            <span class="label">Perf Data:</span>
                            <span class="value code">@DisplayData(details.perfData)</span>
                        </div>
                        
                        <div class="metric-row">
                            <span class="label">Latency:</span>
                            <span class="value">@($"{details.latency * 1000} ms")</span>
                        </div>

                        <div class="metric-row span-full">
                            <span class="label">Status:</span>
                            <span class="bar-full @GetNagiosStateClass(details.currentState)">
                                @GetNagiosStateLabel(details.currentState)</span>
                        </div>
                    
                    </div>
                }
            }
            else
            {
                <p class="text-muted p-3">No live data available.</p>
            }
        </div>
    }
</div>

@code 
{
    [Parameter]
    public AppModel App { get; set; } = default!;

    [Parameter]
    public EventCallback<AppModel> OnExpand { get; set; }

    [Parameter]
    public DateTime LastRefresh { get; set; }

    private DateTime trackedRefresh;

    private bool IsExpanded { get; set; }

    private bool isLoadingDetails = false;
    private AppDetails? details;

    private async Task ExpandAsync()
    {
        IsExpanded = !IsExpanded;

        if (IsExpanded && details == null)
        {
            isLoadingDetails = true;
            try
            {
                details = await LoadService.GetDetailsAsync(App);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error loading details: {ex.Message}");
            }
            finally
            {
                isLoadingDetails = false;
            }
        }

        if (OnExpand.HasDelegate)
        {
            await OnExpand.InvokeAsync(App);
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (IsExpanded && LastRefresh != trackedRefresh)
        {
            trackedRefresh = LastRefresh;

            try
            {
                var newDetails = await LoadService.GetDetailsAsync(App);
                
                if (newDetails != null) 
                {
                    details = newDetails;
                }

                StateHasChanged();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error updating live metrics: {ex.Message}");
            }
        }
    }

    private string GetStatusClass() => App.Status switch
    {
        StatusType.Operational => "status-operational",
        StatusType.DegradedPerformance => "status-degraded",
        StatusType.Outage => "status-outage",
        _ => "status-unknown"
    };

    private string GetDynamicBarColor(double percentage)
    {
        if (percentage < 60) return "bar-green";
        if (percentage < 85) return "bar-yellow";
        return "bar-red";
    }

    private string DisplayData(string value)
    {
        return string.IsNullOrWhiteSpace(value) ? "No data found" : value;
    }

    private string GetNagiosStateLabel(int state) => state switch
    {
        0 => "OK", 1 => "WARNING", 2 => "CRITICAL", 3 => "UNKNOWN", _ => "N/A"
    };

    private string GetNagiosStateClass(int state) => state switch
    {
        0 => "bg-success", 1 => "bg-warning", 2 => "bg-danger", _ => "bg-secondary"
    };
}


<style>
    .app-tile {
        background-color: #3D3D3D;
        border-radius: 8px;
        padding: 12px 16px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        color: white;
    }

    .tile-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .app-tile:hover {
        background-color: #4D4D4D;
    }

    .status-indicator {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .status-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
    }

    .expand-btn, .edit-btn{
        background: transparent;
        border: none;
        color: #ffffff;
        opacity: 0.75;
        padding: 4px;
        border-radius: 4px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .expand-btn:hover, .edit-btn:hover{
        opacity: 1;
        background-color: rgba(255, 255, 255, 0.08);
        transform: scale(1.1);
    }

    .expand-icon, .edit-icon{
        display: block;
        transition: transform 0.3s ease;
    }

    .edit-btn{
        margin-left: -5px;
    }

    .expanded .expand-icon {
        transform: rotate(45deg);
    }

    /* Details section */
    .app-tile {
        transition: all 0.3s ease-in-out;
    }

    .app-tile.expanded {
        padding-bottom: 16px;
    }

    .details {
        margin-top: 12px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 8px;
        padding: 12px;
        width: 100%;
        animation: slideDown 0.3s ease-out;
        transform-origin: top;
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: scaleY(0);
            max-height: 0;
        }

        to {
            opacity: 1;
            transform: scaleY(1);
            max-height: 500px;
        }
    }

    .metrics {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px 16px;
    }

    .metric,
    .metric-row {
        display: flex;
        flex-direction: column;
        gap: 6px;
        margin: 0;
    }

    .metric .label,
    .metric-row .label {
        font-size: 12px;
        color: #BDBDBD;
        margin-bottom: -8px;
    }

    .metric .value {
        font-size: 13px;
        color: #FFFFFF;
        font-weight: 600;
    }

    .section-divider {
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #2D2D2D; 
        padding: 6px 0;
        border-radius: 4px;
        margin-top: 8px; 
        margin-bottom: -8px;
    }

    .section-divider span {
        color: #888888;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        line-height: 1;
    }

    .metric-card {
        background-color: #383838;
        border: 1px solid #4a4a4a;
        border-radius: 8px;
        padding: 24px;
        margin-top: 12px;
    }

    .metric-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        row-gap: 16px;
        column-gap: 40px;
        margin-top: 12px;
    }

    .metric-block {
        display: flex;
        flex-direction: column;
    }

    .span-full {
        grid-column: 1 / -1;
    }

    .metric-label {
        color: #a0a0a0;
        font-size: 13px;
        margin-bottom: 8px;
    }

    .metric-value {
        color: #ffffff;
        font-size: 16px;
        font-weight: 700;
    }

    .bar-track {
        background-color: #4a4a4a;
        height: 6px;
        border-radius: 3px;
        width: 100%;
        overflow: hidden;
        margin-top: 4px;
    }

    .muted {
        color: #CCCCCC;
        font-size: 13px;
    }

    .bar {
        height: 6px;
        border-radius: 4px;
        background: rgba(255, 255, 255, 0.12);
        overflow: hidden;
    }

    .bar-fill {
        height: 100%;
    }

    .bar-yellow {
        background: #FFC107;
    }

    .bar-red {
        background: #F44336;
    }

    .bar-green {
        background: #4CAF50;
    }

    .bar-full {
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #2D2D2D; 
        padding: 1px 0;
        border-radius: 4px;
        margin-top: 8px;
    }

    .status-operational .status-dot {
        background-color: #4CAF50;
    }

    .status-degraded .status-dot {
        background-color: #FFC107;
    }

    .status-outage .status-dot {
        background-color: #F44336;
    }

    .status-unknown .status-dot {
        background-color: #9E9E9E;
    }
</style>